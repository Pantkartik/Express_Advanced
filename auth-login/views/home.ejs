<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 min-h-screen p-10">
    <div class="max-w-3xl mx-auto">
        <div class="flex items-center justify-between mb-8">
            <h1 class="text-3xl font-bold text-white">Registered Users</h1>
            <form method="post" action="/logout">
                <button type="submit" class="rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-500">
                    Logout
                </button>
            </form>
        </div>

        <% if (users.length === 0) { %>
            <p class="text-gray-400 text-center mt-20 text-lg">No users found.</p>
        <% } else { %>
            <div class="overflow-hidden rounded-xl border border-white/10">
                <table class="w-full text-sm text-left text-gray-300">
                    <thead class="bg-white/5 text-gray-400 uppercase text-xs">
                        <tr>
                            <th class="px-6 py-4">Username</th>
                            <th class="px-6 py-4">Email</th>
                            <th class="px-6 py-4">Age</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(function(user) { %>
                            <tr class="border-t border-white/5 hover:bg-white/5 transition">
                                <td class="px-6 py-4 text-white font-medium"><%= user.username %></td>
                                <td class="px-6 py-4"><%= user.email %></td>
                                <td class="px-6 py-4"><%= user.age || '—' %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>

        <div class="mt-6 text-center">
            <a href="/create" class="text-indigo-400 hover:text-indigo-300 text-sm font-semibold">
                Add another user
            </a>
        </div>
    </div>
</body>
</html>